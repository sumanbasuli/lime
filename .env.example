# Bundled PostgreSQL bootstrap settings
POSTGRES_USER=lime
POSTGRES_PASSWORD=lime_dev_password
POSTGRES_DB=lime_db

# App runtime configuration for native local development
DATABASE_URL=postgresql://lime:lime_dev_password@localhost:5432/lime_db?sslmode=disable
SHOPKEEPER_URL=http://localhost:8080

# Shopkeeper
LIME_API_PORT=8080

# UI
LIME_UI_PORT=3000
