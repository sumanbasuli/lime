type=\"text/javascript\" src=\"/C21370_tsa/web/js/bootstrap-accessibility.js\"></script>\n<script type=\"text/javascript\" src=\"/C21370_tsa/web/js/extend.js\"></script>\n<script type=\"text/javascript\" src=\"/C21370_tsa/web/js/common.js\"></script>\n<script type=\"text/javascript\" src=\"/C21370_tsa/web/js/currency.js\"></script>\n<script type=\"text/javascript\" src=\"/C21370_tsa/web/js/toggle_lang.js\"></script>\n<script type=\"text/javascript\" src=\"/C21370_tsa/web/js/bootstrap-toast.js\"></script>\n<script type=\"text/javascript\" src=\"/C21370_tsa/web/js/bootstrap-modal/bootstrap-modals.js\"></script><script type=\"text/javascript\" src=\"/C21370_tsa/web/js/bootstrap-modal/bootstrap-modals.i18n-en.js\"></script>\n<script type=\"text/javascript\" src=\"/C21370_tsa/web/js/jquery/jquery.timers.js\"></script>\n<script type=\"text/javascript\" src=\"/C21370_tsa/web/js/jquery/jquery.bootstrap.stackable.modals.js\"></script>\n<script type=\"text/javascript\" src=\"/C21370_tsa/web/js/spinner.js\"></script>\n<script type=\"text/javascript\" src=\"/C21370_tsa/web/js/please-wait.js\"></script>\n<script type=\"text/javascript\" src=\"/C21370_tsa/web/lib/datatables/1.10.15/datatables.min.js\"></script><script type=\"text/javascript\" src=\"/C21370_tsa/web/lib/datatables/1.10.15/datatables.i18n-en.min.js\"></script>\n<script type=\"text/javascript\" src=\"/C21370_tsa/web/js/datatables-init.js\"></script>\n<script type=\"text/javascript\" src=\"/C21370_tsa/web/js/datatables-fixes.js\"></script>\n<script type=\"text/javascript\" src=\"/C21370_tsa/web/js/datatables-defaults.js\"></script>\n<script type=\"text/javascript\" src=\"/C21370_tsa/web/js/ajax-submit.js\"></script>\n<script type=\"text/javascript\" src=\"/C21370_tsa/web/js/apple_pay.js\"></script>\n<script type=\"text/javascript\" src=\"/C21370_tsa/web/js/polyfills.js\"></script>\n<script type=\"text/javascript\" src=\"/C21370_tsa/web/js/react/react.production.min.js\"></script>\n<script type=\"text/javascript\" src=\"/C21370_tsa/web/js/react/react-dom.production.min.js\"></script>\n<script type=\"text/javascript\" src=\"/C21370_tsa/web/js/password-complexity.js\"></script>\n<script type=\"text/javascript\" src=\"/C21370_tsa/web/js/banner-messages.js\"></script>\n<script type=\"text/javascript\" src=\"/C21370_tsa/web/js/agreement.js\"></script>\n<script type=\"text/javascript\" src=\"/C21370_tsa/web/js/messages.js\"></script>\n<script type=\"text/javascript\" src=\"/C21370_tsa/web/js/jquery/mask/jquery.mask.js\"></script>\n\n\n\n\n\n\n\n\n\n<script nonce=\"\">\n\n  \n  const AMOUNTS_CONFIGURATION = {\n    allowZeroPayment: true,\n    currencySign: '\\x24',\n    decimalSeparator: '.',\n    groupingSeparator: ',',\n    maxAllowedPaymentValue: '99999.99'\n  };\n  \n\n</script>\n\n\n\n\n\n\n<script type=\"text/javascript\" src=\"/C21370_tsa/web/js/formValidation.js\"></script>\n\n\n\n\n  \n  \n\n\n\n\n\n\n\n\n\n  <title>Login Page</title>\n\n  \n  \n  <!-- TouchNet Bill&#x2b;Payment Suite 9.4.0 Build 9 &#x28; 04&#x2f;14&#x2f;2026 18&#x3a;14&#x3a;27 UTC &#x29; -->\n  <!-- AC 2 -->\n\n  \n\n\n\n  <style>\n    .loginFullPageBackground {\n      background: url('/C21370_tsa/web/images/fullpage.jpg') no-repeat center;\n    }\n  </style>\n\n\n\n</head>\n\n<body id=\"login\" class=\"loginFullPageBackground loginFullPageBackground\">\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n<div id=\"skipNav\">\n  <a id=\"skipNavigationToMainContent\" class=\"sr-only sr-only-focusable\" href=\"#skipNavigationToMainContent\">\n    Skip to Login\n  </a>\n</div><!--used for skip navigation-->\n\n<div id=\"ariaLive\" class=\"hidden\">\n  <div id=\"mainLiveRegion\" role=\"log\" aria-live=\"assertive\" aria-atomic=\"false\" aria-relevant=\"text\"></div>\n</div><!-- it is used for 508 compliance - this invisible field is for screen readers in situations when we update some area\nwithout having focus on it -->\n\n<script type=\"text/javascript\" src=\"/C21370_tsa/web/js/skip_navigation.js\"></script>\n<script nonce=\"\">\n    $( function()\n    {\n      $( \"a.payment-date-skip-navigator\" ).skip_navigation_to( \"#paymentDatePicker\" );\n\n      var skipFocus = function( navOrContent )\n      {\n        var contentSelectorWrapper = \".container, .container-fluid\";\n        var navSelectorWrapper = \"nav\";\n        var focusSelectors = [ \"*[tabindex]:visible\", \"input:visible\", \"select:visible\",\n                               \"textarea:visible\", \"button:visible\", \"a:visible\" ];\n\n        var focusToSelector = \"\";\n\n        if ( navOrContent === \"nav\" )\n        {\n          focusToSelector = navSelectorWrapper;\n        }\n        else if ( navOrContent === \"content\" )\n        {\n          focusToSelector = contentSelectorWrapper;\n        }\n\n        $( focusToSelector ).find( focusSelectors.join() ).first().focus();\n      };\n\n      var skipToNavClickHandler = function( event )\n      {\n        event.preventDefault();\n        skipFocus( \"nav\" );\n      };\n\n      var skipToContentClickHandler = function( event )\n      {\n        event.preventDefault();\n        skipFocus( \"content\" );\n      };\n\n      $( '#skipToNav' ).bind( \"click\", skipToNavClickHandler );\n      $( '#skipNav' ).bind( \"click\", skipToContentClickHandler );\n    } );\n</script>\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n  \n    <header id=\"header\" class=\"pageHeader\">\n    <a class=\"pull-left hidden-print inactiveLink\" aria-label=\"Shelton State Community College Home Page\" href=\"\">\n      <img class=\"hidden-print img-responsive\" src=\"/C21370_tsa/web/images/header.jpg\" alt=\"Shelton State Community College Home Page\">\n    </a>\n  \n  <div class=\"printHeader\">\n    <img id=\"printHeader\" src=\"/C21370_tsa/web/images/printHeader.jpg\" alt=\"Bill+Payment Header\">\n  </div>\n\n  \n\n  \n\n  \n    </header>\n  \n\n\n\n\n\n\n\n\n\n  \n  \n    \n\n\n\n\n\n  \n\n\n\n\n<div id=\"languageToggleBox\" class=\"transparent50 bottomCorners hidden\">\n  <div class=\"topLinks\">\n    \n    \n      \n\n      <a id=\"switchLang_en\" class=\"cursor-pointer text-capitalize\" data-toggle-lang=\"en\" title=\"Switch language\">\n          <b>\n          english\n          </b>\n      </a>\n    \n  </div>\n</div>\n\n<script nonce=\"\">\n  $(function () {\n    $(\"[id^='switchLang_']\").on('click', function (e) {\n      e.preventDefault();\n      let lang = $(this).data('toggleLang');\n      toggleLanguage(lang);\n    });\n  });\n</script>\n\n    \n\n    <h1 class=\"sr-only\">Login Page</h1>\n\n    <div id=\"loginContainer\" class=\"container  loginFormMarginTop\">\n      <div class=\"row\">\n        <div class=\"panel panel-default\">\n          <div class=\"panel-body\">\n            <div id=\"loginForms\" class=\"col-xs-12 col-md-4\">\n              \n\n              \n                <h2 class=\"loginHeader mb-3\">Welcome to Shelton State Community College!</h2>\n              \n\n              \n\n              \n                \n\n                \n                \n                  \n\n\n\n\n\n\n\n\n<div id=\"messageHolder\">\n  \n</div>\n\n\n<div id=\"scriptMessages\" class=\"alert alert-warning\"></div>\n\n                \n              \n\n              \n                \n\n\n\n\n\n\n\n  \n    \n\n    \n\n\n  <div class=\"alert alert-warning\" role=\"alert\"><p>Login for parents or others who have been granted access.</p>\n</div>\n\n\n\n    \n\n\n\n\n\n\n\n\n\n\n\n<form name=\"Form2\" id=\"UserLoginFormId\" action=\"/C21370_tsa/tapp\" method=\"post\" class=\"form-horizontal\">\n  <input type=\"hidden\" name=\"tapp-stoken\" value=\"B2q8Zrt9rg6\">\n  <input type=\"hidden\" name=\"Navigate\" value=\"welcome.jsp\">\n  <input type=\"hidden\" name=\"OnError\" value=\"login.jsp\">\n  <input type=\"hidden\" name=\"AUTHUSER\" value=\"true\">\n  <input type=\"hidden\" name=\"REDIRECT\" value=\"\">\n  <input type=\"hidden\" name=\"REDIRECT_PARAMETER\" value=\"\">\n\n  <div class=\"form-group\">\n    <label class=\"sr-only\" for=\"userEmail\">Email:</label>\n    <div class=\"col-xs-12\">\n      <input type=\"text\" name=\"USER\" id=\"userEmail\" class=\"form-control\" autocomplete=\"off\" required=\"\" value=\"\" placeholder=\"Email:\">\n    </div>\n  </div>\n\n  <div class=\"form-group\">\n    <label class=\"sr-only\" for=\"pwd\">Password:</label>\n    <div class=\"col-xs-12\">\n      <div class=\"input-group\" id=\"password_container\">\n      <input type=\"password\" name=\"PASS\" id=\"pwd\" class=\"form-control\" autocomplete=\"off\" maxlength=\"255\" required=\"\" placeholder=\"Password:\">\n        <div class=\"input-group-addon \">\n          <i class=\"fa fa-eye\" id=\"authUserPasswordToggle\" aria-hidden=\"true\"></i>\n        </div>\n      </div>\n    </div>\n  </div>\n\n  \n\n  <div class=\"form-group\">\n    <div class=\"pull-right\">\n      <a id=\"mailYou_L\" class=\"text-danger mr-3\" title=\"Sends a temporary password\" tabindex=\"0\">\n        Forgot Password\n      </a>\n      <button id=\"authUserLoginBtn\" class=\"btn btn-primary mr-3\">\n        Login\n      </button>\n    </div>\n  </div>\n\n  \n  \n\n  \n</form>\n\n<form name=\"FormEmail\" action=\"/C21370_tsa/tapp\" method=\"post\">\n  <input type=\"hidden\" name=\"tapp-stoken\" value=\"B2q8Zrt9rg6\">\n  <input type=\"hidden\" name=\"Navigate\" value=\"login.jsp\">\n  <input type=\"hidden\" name=\"OnError\" value=\"login.jsp\">\n  <input type=\"hidden\" name=\"RESET_AUTH_USER_PASSWORD_ACTION\" value=\"\">\n  <input type=\"hidden\" name=\"USER\" value=\"\">\n  <input type=\"hidden\" name=\"REDIRECT\" value=\"\">\n</form>\n\n<script nonce=\"\">\n  let fClicked = false;\n\n  function sendEmail()\n  {\n    let Form2 = document.Form2;\n    let FormEmail = document.FormEmail;\n\n    if ( Form2.USER.value.length <= 0 )\n    {\n      showAlert( {body: 'You must provide your e-mail address to have your password sent to you.'} );\n    }\n    else\n    {\n      if ( !fClicked )\n      {\n        fClicked = true;\n        FormEmail.USER.value = Form2.USER.value;\n        FormEmail.submit();\n      }\n    }\n  }\n\n  function inputsOk( form )\n  {\n    let user = form.USER.value;\n    let pass = form.PASS.value;\n\n    if ( user.length === 0 || pass.length === 0 )\n    {\n      if ( form.name === \"Form1\" )\n      {\n        showAlert( {body: 'Please enter both your ID and Banner PIN to log in.'} );\n      }\n      else if ( form.name === \"Form2\" )\n      {\n        showAlert( {body: 'Please enter both your E-mail Address and Password to log in.'} );\n      }\n      return false;\n    }\n    return true;\n  }\n\n  function handleLogin( form )\n  {\n    if ( !fClicked && inputsOk( form ) )\n    {\n      fClicked = true;\n      doit( form );\n    }\n    event.returnValue = false;\n  }\n\n  function doit( form )\n  {\n    spinnerModal();\n    form.submit();\n  }\n\n  $( function()\n  {\n    $('#captchaAuthUser').on('keypress', function ()\n    {\n      keyTrap( document.Form2 );\n    } );\n\n    $('#pwd').submit( function ()\n    {\n      return handleLogin( document.Form2 );\n    } );\n  } );\n  document.getElementById( 'authUserPasswordToggle' ).addEventListener( 'click', function (  )\n  {\n    const passwordField = document.getElementById( 'pwd' );\n    const type = passwordField.getAttribute( 'type' ) === 'password' ? 'text' : 'password';\n    passwordField.setAttribute( 'type', type );\n\n    if ( type === 'password' )\n    {\n      this.classList.remove( 'fa-eye-slash' );\n      this.classList.add( 'fa-eye' );\n    }\n    else\n    {\n      this.classList.remove( 'fa-eye' );\n      this.classList.add( 'fa-eye-slash' );\n    }\n  }\n  )\n\n  const forgotPasswordLink = $( '#mailYou_L' );\n\n  forgotPasswordLink.click( function( event )\n  {\n    event.preventDefault();\n    sendEmail();\n  } );\n\n  forgotPasswordLink.keypress( function( event )\n  {\n    event.preventDefault();\n\n    if ( event.keyCode === 13 )\n    {\n      forgotPasswordLink.click();\n    }\n  } );\n</script>\n\n\n    \n  \n  \n\n\n\n              \n            </div>\n\n            \n              <div class=\"col-xs-12 col-md-offset-1 col-md-7\">\n                  <p>\n  <strong>Shelton State Student Account&nbsp;Features</strong>\n</p>\n<ul>\n  <li>Check your balance.\n  </li><li>Make a payment towards your balance.\n  </li><li>View your payment history.\n  </li><li>Store your payment methods for quick and easy payment.\n  </li><li>As a student, provide permission to others (parents, employers,\n    etc.) to view your bill and make payments.*\n</li></ul>\n<p>*Parents, guardians, and&nbsp;employers require student permission to\n  access account information.&nbsp;</p>\n<p>For help, visit <strong>\n    <a href=\"http://www.sheltonstate.edu/wp-content/uploads/2019/08/Adding-an-Authorized-User-to-Your-Account.pdf\">Adding\n      an Authorized User to Your Account</a></strong> and <strong>\n    <a href=\"http://www.sheltonstate.edu/wp-content/uploads/2019/08/Authorized-Users-Instructions.pdf\">Authorized\n      Users Instructions</a></strong>.&nbsp;</p>\n<p>For additional information,&nbsp;visit <strong>\n    <a href=\"http://www.sheltonstate.edu/wp-content/uploads/2019/08/Payment-Overview.pdf\">Payment\n  Overview</a>&nbsp;</strong>and <strong>\n    <a href=\"http://www.sheltonstate.edu/wp-content/uploads/2019/08/Making-a-Payment.pdf\">Making\n      a Payment</a></strong>.</p>\n<p>To review steps for eRefund registration, visit <strong>\n    <a href=\"https://my.sheltonstate.edu/c/document_library/get_file?uuid=1c77e2c1-b4f5-4f29-b7b9-7c6c402751b5&amp;groupId=10217&amp;filename=eRefund%20Directions%20PAG%20Approved\">eRefund Directions</a></strong>.</p>\n\n              </div>\n            \n          </div>\n        </div>\n      </div>\n    </div>\n  \n\n\n<script nonce=\"\">\n  $( function () {\n    \n      \n      \n        if ( document.Form1 && document.Form1.USER.value.length > 0 )\n        {\n          document.Form1.USER.focus();\n        }\n        else if ( document.Form2 && document.Form2.USER.value.length > 0 )\n        {\n          document.Form2.USER.focus();\n        }\n        else if ( document.Form1 )\n        {\n          document.Form1.USER.focus();\n        }\n        else if ( document.Form2 )\n        {\n          document.Form2.USER.focus();\n        }\n\n        \n\n        \n\n        $( '#loginForms' ).on( 'show.bs.collapse', '.collapse', function () {\n          $( '#loginForms' ).find( '.collapse.in' ).collapse( 'hide' );\n        } );\n\n        function openLoginForm( selector )\n        {\n          let $target = $( 'body' ).find( selector );\n\n          if ( $target.length )\n          {\n            $target.click();\n          }\n        }\n\n        if ( false )\n        {\n          openLoginForm( '#student' );\n        }\n        else if ( window.location.hash )\n        {\n          openLoginForm( window.location.hash );\n        }\n      \n    \n\n    $('#captchaStudent').on('keypress', function ()\n    {\n      keyTrap( document.Form1 );\n    } );\n\n    $('#pin').submit( function ()\n    {\n      return handleLogin( document.Form1 );\n    } );\n\n    $( '#studentLoginBtn' ).on( 'click', function ( e )\n    {\n      e.preventDefault();\n      const studentLoginForm = $( '#StudentLoginFormId' )[ 0 ];\n\n      if ( studentLoginForm.checkValidity() )\n      {\n        spinnerModal();\n        studentLoginForm.submit();\n      } else\n      {\n        studentLoginForm.reportValidity();\n      }\n    } );\n\n    $( '#authUserLoginBtn' ).on( 'click', function ( e )\n    {\n      e.preventDefault();\n      const authUserLoginForm = $( '#UserLoginFormId' )[ 0 ];\n\n      if ( authUserLoginForm.checkValidity() )\n      {\n        spinnerModal();\n        authUserLoginForm.submit();\n      } else\n      {\n        authUserLoginForm.reportValidity();\n      }\n    } );\n\n\n  } );\n</script>\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n<div id=\"footerContainer\">\n<style>\n  .footer-template {\n    position: absolute;\n    bottom: 0;\n    width: 100%;\n    min-height: 55px;\n    max-height: 180px;\n  }\n\n  .footer-template .footer-template-content {\n    display: block;\n    line-height: 24px;\n    padding: 15px;\n    z-index: 3;\n    word-break: break-word;\n    font-size: 16px;\n    font-family: Arial, \"Helvetica Neue\", Helvetica, sans-serif;\n  }\n\n  .footer-template .footer-template-links {\n    font-variant: normal;\n    font-weight: 500;\n    padding-left: 10px;\n  }\n\n  .footer-template .footer-template-links .footer-link-delimiter {\n    font-family: Arial, \"Helvetica Neue\", Helvetica, sans-serif;\n    opacity: 0.5;\n    padding-left: 15px;\n    padding-right: 15px;\n  }\n\n  .footer-template .footer-template-brand {\n    display: flex;\n    align-items: flex-end;\n    flex-direction: column;\n    padding-left: 10px;\n    padding-right: 15px;\n  }\n\n  @media (max-width: 768px) {\n    .footer-template .footer-template-brand {\n        align-items: flex-start;\n    }\n  }\n\n  .footer-template .footer-template-copyright-text p {\n    margin: 0;\n  }\n\n  .footerLogo .img-responsive {\n    max-height: 200px;\n  }\n\n  .footer-template, .footer-template-content {\n    background: #ffffff;\n    color: #444444 !important;\n  }\n\n  .footer-template, .footer-template-links {\n    font-family: Segoe UI;\n  }\n\n  .footer-template .footer-template-links a {\n    color: #106a37;\n    text-decoration: none;\n  }\n\n  .footer-template .footer-template-links a:hover,\n  .footer-template .footer-template-links a:focus {\n    color: #106a37;\n    text-decoration: none;\n  }\n</style>\n\n<footer class=\"footer-template\">\n  <div class=\"container-fluid footer-template-content\">\n    <div class=\"row\">\n      <div class=\"col-md-6 col-xs-12\">\n        <div class=\"footer-template-links\">\n          <span> <a target=\"_blank\" href=\"https://www.sheltonstate.edu/privacy-policy/\">Privacy Policy\n        <span class=\"sr-only\">Opens in new window</span></a></span>\n        </div>\n      </d