n    function renderFooter( layoutTemplate, brandingTemplate )\n    {\n      const layoutTemplateDesignComponent = layoutTemplate.componentList\n          .find( component => component.type === 'FOOTER' ) ?? {};\n\n      const brandingTemplateDesignComponent = brandingTemplate.componentList\n          .find( component => component.type === 'FOOTER' ) ?? {};\n\n      const layoutTemplateProperties = layoutTemplateDesignComponent.propertyList ?? [];\n\n      const links = getSubpropertyList( layoutTemplateProperties, 'LINK_LIST' );\n      const linksHtml = getLinksHtml(\n          getSubpropertyList( links, 'LINK', 'privacyPolicy' ),\n          getSubpropertyList( links, 'LINK', 'accessibility' ) );\n\n      const copyright = layoutTemplateProperties.find( prop => prop.type === 'CONTENT' )?.value ?? '';\n\n      const logo = getSubpropertyList( layoutTemplateProperties, 'IMAGE' );\n      const logoPath = getPropertyValue( logo, 'path' );\n      const logoStoragePath = getPropertyValue( logo, 'storagePath' );\n      const logoUrl = getPropertyValue( logo, 'url' );\n      const logoAltText = getPropertyValue( logo, 'altText' );\n\n      const templateScope = layoutTemplate?.scope ?? '';\n\n      const logoHtml = getLogoHtml( logoPath, logoStoragePath, logoUrl, logoAltText, templateScope );\n\n      const brandingTemplateProperties = brandingTemplateDesignComponent.propertyList ?? [];\n\n      const fontFamily = getSubpropertyList( brandingTemplateProperties, 'FONT', 'body' )\n          ?.find( prop => prop.type === 'TEXT' )?.value ?? '';\n\n      const hyperlinks = getSubpropertyList( brandingTemplateProperties, 'FONT', 'hyperlinks' );\n\n      const DEFAULT_LINKS_COLOR = '#cccccc';\n      const DEFAULT_LINKS_DECORATION = 'none';\n      const DEFAULT_LINKS_COLOR_HOVER = '#cccccc';\n      const DEFAULT_LINKS_DECORATION_HOVER = 'none';\n\n      const hyperlinksColor = getPropertyValue( hyperlinks, 'color', DEFAULT_LINKS_COLOR );\n      const hyperlinksDecoration = getPropertyValue( hyperlinks, 'decoration', DEFAULT_LINKS_DECORATION );\n      const hyperlinksColorHover = getPropertyValue( hyperlinks, 'colorHover', DEFAULT_LINKS_COLOR_HOVER );\n      const hyperlinksDecorationHover = getPropertyValue( hyperlinks, 'decorationHover', DEFAULT_LINKS_DECORATION_HOVER );\n\n      const colorSchemeProperties = getSubpropertyList( brandingTemplateProperties, 'FONT',\n          'colorScheme' );\n\n      const DEFAULT_FONT_COLOR = '#cccccc';\n      const DEFAULT_BACKGROUND_COLOR = '#00467F';\n\n      const fontColor = getPropertyValue( colorSchemeProperties, 'color', DEFAULT_FONT_COLOR );\n      const backgroundColor = getPropertyValue( colorSchemeProperties, 'background', DEFAULT_BACKGROUND_COLOR );\n\n      const FOOTER_HTML_TEMPLATE = `\n<style>\n  .footer-template {\n    position: absolute;\n    bottom: 0;\n    width: 100%;\n    min-height: 55px;\n    max-height: 180px;\n  }\n\n  .footer-template .footer-template-content {\n    display: block;\n    line-height: 24px;\n    padding: 15px;\n    z-index: 3;\n    word-break: break-word;\n    font-size: 16px;\n    font-family: Arial, \"Helvetica Neue\", Helvetica, sans-serif;\n  }\n\n  .footer-template .footer-template-links {\n    font-variant: normal;\n    font-weight: 500;\n    padding-left: 10px;\n  }\n\n  .footer-template .footer-template-links .footer-link-delimiter {\n    font-family: Arial, \"Helvetica Neue\", Helvetica, sans-serif;\n    opacity: 0.5;\n    padding-left: 15px;\n    padding-right: 15px;\n  }\n\n  .footer-template .footer-template-brand {\n    display: flex;\n    align-items: flex-end;\n    flex-direction: column;\n    padding-left: 10px;\n    padding-right: 15px;\n  }\n\n  @media (max-width: 768px) {\n    .footer-template .footer-template-brand {\n        align-items: flex-start;\n    }\n  }\n\n  .footer-template .footer-template-copyright-text p {\n    margin: 0;\n  }\n\n  .footerLogo .img-responsive {\n    max-height: 200px;\n  }\n\n  .footer-template, .footer-template-content {\n    background: ${backgroundColor};\n    color: ${fontColor} !important;\n  }\n\n  .footer-template, .footer-template-links {\n    font-family: ${fontFamily};\n  }\n\n  .footer-template .footer-template-links a {\n    color: ${hyperlinksColor};\n    text-decoration: ${hyperlinksDecoration};\n  }\n\n  .footer-template .footer-template-links a:hover,\n  .footer-template .footer-template-links a:focus {\n    color: ${hyperlinksColorHover};\n    text-decoration: ${hyperlinksDecorationHover};\n  }\n</style>\n\n<footer class=\"footer-template\">\n  <div class=\"container-fluid footer-template-content\">\n    <div class=\"row\">\n      <div class=\"col-md-6 col-xs-12\">\n        <div class=\"footer-template-links\">\n          <span>${linksHtml}</span>\n        </div>\n      </div>\n      <div class=\"col-md-6 col-xs-12\">\n        <div class=\"footer-template-brand\">\n          <span class=\"footerLogo\">${logoHtml}</span>\n          <span class=\"footer-template-copyright-text\">${copyright}</span>\n        </div>\n      </div>\n    </div>\n  </div>\n</footer>`;\n\n      $( '#footerContainer' )\n          .append( FOOTER_HTML_TEMPLATE );\n    }\n\n    function getPropertyValue( property, propertyName, defaultValue )\n    {\n      defaultValue = defaultValue ?? '';\n\n      return property.find( prop => prop.name === propertyName )?.value ?? defaultValue;\n    }\n\n    function getSubpropertyList( properties, type, name )\n    {\n      if ( type && name )\n      {\n        return properties.find( prop => prop.type === type && prop.name === name )?.subpropertyList ?? [];\n      }\n      else\n      {\n        return properties.find( prop => prop.type === type )?.subpropertyList ?? [];\n      }\n    }\n\n    function getLinksHtml( privacyPolicyLink, accessibilityLink )\n    {\n      const DEFAULT_PRIVACY_URL_ORDER = 1;\n      const DEFAULT_ACCESSIBILITY_URL_ORDER = 2;\n\n      const privacyPolicyLinkDisplayName = getPropertyValue( privacyPolicyLink, 'displayName' );\n      const privacyPolicyLinkUrl = getPropertyValue( privacyPolicyLink, 'url' );\n      let privacyPolicyLinkSortOrder = getPropertyValue( privacyPolicyLink, 'sortOrder', DEFAULT_PRIVACY_URL_ORDER );\n      privacyPolicyLinkSortOrder = isNaN( privacyPolicyLinkSortOrder ) ? DEFAULT_PRIVACY_URL_ORDER : Number( privacyPolicyLinkSortOrder );\n\n      const accessibilityLinkDisplayName = getPropertyValue( accessibilityLink, 'displayName' );\n      const accessibilityLinkUrl = getPropertyValue( accessibilityLink, 'url' );\n      let accessibilityLinkSortOrder = getPropertyValue( accessibilityLink, 'sortOrder', DEFAULT_ACCESSIBILITY_URL_ORDER );\n      accessibilityLinkSortOrder = isNaN( accessibilityLinkSortOrder ) ? DEFAULT_ACCESSIBILITY_URL_ORDER : Number( accessibilityLinkSortOrder );\n\n      const privacyPolicyUrlHtml =\n          privacyPolicyLinkDisplayName.length > 0 && privacyPolicyLinkUrl.length > 0 ?\n              ` <a target=\"_blank\" href=\"${checkHttpProtocol( privacyPolicyLinkUrl )}\">${privacyPolicyLinkDisplayName}\n        <span class=\"sr-only\">Opens in new window</span></a>` : '';\n\n      const accessibilityPolicyUrlHtml =\n          accessibilityLinkDisplayName.length > 0 && accessibilityLinkUrl.length > 0 ?\n              ` <a target=\"_blank\" href=\"${checkHttpProtocol( accessibilityLinkUrl )}\">${accessibilityLinkDisplayName}\n        <span class=\"sr-only\">Opens in new window</span></a>` : '';\n\n      const linkDelimiter = `<span class=\"footer-link-delimiter\">|</span>`;\n\n      if ( !privacyPolicyUrlHtml )\n      {\n        return accessibilityPolicyUrlHtml;\n      }\n\n      if ( !accessibilityPolicyUrlHtml )\n      {\n        return privacyPolicyUrlHtml;\n      }\n\n      if ( privacyPolicyLinkSortOrder > accessibilityLinkSortOrder )\n      {\n        return accessibilityPolicyUrlHtml + linkDelimiter + privacyPolicyUrlHtml;\n      }\n      else\n      {\n        return privacyPolicyUrlHtml + linkDelimiter + accessibilityPolicyUrlHtml;\n      }\n    }\n\n    function checkHttpProtocol( url )\n    {\n      return url.startsWith( \"https://\" ) || url.startsWith( \"http://\" ) ? url : \"//\" + url;\n    }\n\n    function getLogoHtml( logoPath, logoStoragePath, logoUrl, logoAltText, templateScope )\n    {\n      const serverPath = '&#x2f;C21370_tsa&#x2f;';\n\n      const logoImageFullPath = templateScope === 'GLOBAL' ?\n          getUniversalTemplateImageFullPath( logoStoragePath, logoPath, serverPath )\n          :\n          serverPath +\n          'web&#x2f;images&#x2f;footers/'\n          + encodeURIComponent( logoPath );\n\n      if ( logoUrl && ( logoPath || logoStoragePath ) && logoAltText )\n      {\n        return `<a href=\"${logoUrl}\" target=\"_blank\">\n            <img class=\"img-responsive\"\n                           src=\"${logoImageFullPath}\"\n                           alt=\"${logoAltText}\">\n          </a>`;\n      }\n      else if ( logoPath || logoStoragePath )\n      {\n        return `<img class=\"img-responsive\"\n                           src=\"${logoImageFullPath}\"\n                           alt=\"${logoAltText}\">`;\n      }\n      else\n      {\n        return '';\n      }\n    }\n\n    function getUniversalTemplateImageFullPath( cloudStorageImagePath, sharedStorageImagePath, serverPath )\n    {\n      if ( cloudStorageImagePath )\n      {\n        return 'https://storage.googleapis.com/bkt-gousgnaig-tnet-ucomm-dts-universal-template-image/C21370/' + encodeURIComponent( cloudStorageImagePath );\n      }\n\n      return serverPath +\n          'web&#x2f;universal/'\n          + encodeURIComponent( sharedStorageImagePath );\n    }\n\n    function renderDefaultFooter()\n    {\n      const currentYear = new Date().getFullYear();\n      const DEFAULT_FOOTER_HTML =\n          `<footer class=\"footer\">\n              <div class=\"container-fluid footer-content\">\n                <div class=\"row\">\n                  <div class=\"col-xs-12 footerLegal\">\n                        <span>\n                                &copy; ${currentYear} TouchNet <sup>&reg;</sup>\n                        <i>A<strong> Global Payments </strong>Company</i><span class=\"px-1\">|</span>All rights reserved.<span class=\"px-1\">|</span>\n                        <a class=\"text-underline\"\n                           href=\"https://www.touchnet.com/en/technology-solution-privacy-policy\"\n                           target=\"_blank\">Privacy Policy<span class=\"sr-only\">Opens in new window</span>\n                        </a>\n                        </span>\n                      </div>\n                    </div>\n                </div>\n            </footer>`\n\n      $( '#footerContainer' )\n          .append( DEFAULT_FOOTER_HTML );\n    }\n  } );\n</script>\n\n\n\n\n</body></html>","screenshot_path":"/app/screenshots/66386d89-8564-40bb-93b3-c4a6fe70fcd4/5e5b3b14-83bb-492e-bc46-a9f878f2ce22.png","created_at":"2026-04-23T12:19:10.754146","element_screenshot_path":"/app/screenshots/66386d89-8564-40bb-93b3-c4a6fe70fcd4/5e5b3b14-83bb-492e-bc46-a9f878f2ce22_focus_0.png","css_selector":"html"}
