LIME_IMAGE_TAG=v0.1.0
DATABASE_URL=postgresql://username:password@db-host:5432/lime_db?sslmode=disable
SHOPKEEPER_URL=http://shopkeeper:8080
LIME_API_PORT=8080
LIME_UI_PORT=3000

# Optional: check GitHub releases for updates and show notice in sidebar.
# Set to "true" to enable. Default off to avoid outbound calls in air-gapped setups.
LIME_UPDATE_CHECK=false
LIME_GITHUB_REPO=sumanbasuli/lime
