# /etc/lime/ui.env
# UI runtime environment.

DATABASE_URL=postgresql://lime:REPLACE_ME@127.0.0.1:5432/lime_db?sslmode=disable
SHOPKEEPER_URL=http://127.0.0.1:8080
PORT=3000
HOSTNAME=127.0.0.1

# Update notice (off by default; enable to show GitHub release badges in the sidebar).
LIME_UPDATE_CHECK=false
LIME_GITHUB_REPO=sumanbasuli/lime
# LIME_VERSION is written by the installer based on VERSION in the checked-out source.
LIME_VERSION=
