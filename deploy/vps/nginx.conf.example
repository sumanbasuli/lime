# Nginx reverse proxy example for a VPS deployment.
#
# The UI serves everything the browser needs (including /api/...).
# Shopkeeper does not need to be exposed publicly.
#
# Drop this into /etc/nginx/sites-available/lime.conf, replace
# the server_name, add TLS via certbot, then enable with:
#   ln -s /etc/nginx/sites-available/lime.conf /etc/nginx/sites-enabled/
#   nginx -t && systemctl reload nginx

upstream lime_ui {
    server 127.0.0.1:3000;
    keepalive 16;
}

server {
    listen 80;
    server_name lime.example.com;

    # Tighten upload size; LIME rarely posts large bodies.
    client_max_body_size 2m;
    client_body_timeout 60s;

    # Long scan API calls and PDF reports can take several minutes.
    proxy_read_timeout 10m;
    proxy_send_timeout 10m;

    location / {
        proxy_pass http://lime_ui;
        proxy_http_version 1.1;
        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Connection        "";
    }
}
