# /etc/lime/shopkeeper.env
# Shopkeeper runtime environment.

DATABASE_URL=postgresql://lime:REPLACE_ME@127.0.0.1:5432/lime_db?sslmode=disable
SHOPKEEPER_PORT=8080
SHOPKEEPER_SCREENSHOT_DIR=/opt/lime/shopkeeper/screenshots

# Optional: explicit path to ACT catalog. Falls back to /opt/lime/shopkeeper/data/act-rules.json.
# ACT_RULES_PATH=/opt/lime/shopkeeper/data/act-rules.json

# Optional: explicit Chromium binary if auto-detect fails.
# CHROMIUM_PATH=/usr/bin/chromium

# Optional: URL the scanner uses to load the UI when rendering PDF reports.
# REPORT_BASE_URL=http://127.0.0.1:3000
